{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "enabledPlugins": {
    "claude-md-management@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "permissions": {
    "allow": [
      "Edit(*)",
      "Read",
      "WebFetch",
      "WebSearch",
      "Write(*)",
      "Bash(aerospace *)",
      "Bash(brew info *)",
      "Bash(brew list *)",
      "Bash(brew search *)",
      "Bash(cat *)",
      "Bash(chmod *)",
      "Bash(cp *)",
      "Bash(curl *)",
      "Bash(defaults read *)",
      "Bash(diff *)",
      "Bash(echo *)",
      "Bash(env)",
      "Bash(file *)",
      "Bash(find *)",
      "Bash(gh issue view *)",
      "Bash(gh pr view *)",
      "Bash(gh repo view *)",
      "Bash(git add *)",
      "Bash(git branch*)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git ls-tree *)",
      "Bash(git remote *)",
      "Bash(git show *)",
      "Bash(git status*)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(jq *)",
      "Bash(ln *)",
      "Bash(ls *)",
      "Bash(mdfind *)",
      "Bash(mkdir *)",
      "Bash(mv *)",
      "Bash(node *)",
      "Bash(printenv *)",
      "Bash(pwd)",
      "Bash(readlink *)",
      "Bash(realpath *)",
      "Bash(sort *)",
      "Bash(stat *)",
      "Bash(tail *)",
      "Bash(tree *)",
      "Bash(type *)",
      "Bash(uniq *)",
      "Bash(wc *)",
      "Bash(which *)"
    ],
    "ask": ["Bash(git commit *)"],
    "defaultMode": "default",
    "deny": [
      "Read(./.env.local)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Bash(rm -rf *)"
    ]
  },
  "skipWebFetchPreflight": true
}
